# =============================================================================
# RKE2 Cluster — Environment Configuration
# =============================================================================
# Used by: rancher-api-deploy.sh, nuke-cluster.sh
# NOT used by Terraform (see terraform/terraform.tfvars.example)
#
# Setup:
#   cp .env.example .env
#   $EDITOR .env        # fill in real values
#   ./rancher-api-deploy.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Rancher Connection
# -----------------------------------------------------------------------------
RANCHER_URL="https://rancher.example.com"
RANCHER_TOKEN="token-xxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# Harvester
# -----------------------------------------------------------------------------
HARVESTER_CLUSTER_ID="c-xxxxx"
CLOUD_CRED_NAME="my-harvester-credential"

# -----------------------------------------------------------------------------
# Cluster
# -----------------------------------------------------------------------------
CLUSTER_NAME="rke2-prod"
K8S_VERSION="v1.34.2+rke2r1"
CNI="cilium"
TRAEFIK_LB_IP="192.168.48.2"
CILIUM_LB_POOL_START="192.168.48.2"
CILIUM_LB_POOL_STOP="192.168.48.20"

# -----------------------------------------------------------------------------
# Harvester Networking
# -----------------------------------------------------------------------------
VM_NAMESPACE="rke2-prod"
HARVESTER_NETWORK_NAME="vm-network"
HARVESTER_NETWORK_NS="default"
SERVICES_NETWORK_NAME="services-network"
SERVICES_NETWORK_NS="default"

# -----------------------------------------------------------------------------
# Golden Image (must already exist on Harvester)
# -----------------------------------------------------------------------------
GOLDEN_IMAGE_NAME="rke2-rocky9-golden-20260227"

# -----------------------------------------------------------------------------
# Registry / Bootstrap
# -----------------------------------------------------------------------------
BOOTSTRAP_REGISTRY="harbor.example.com"
HARBOR_FQDN="harbor.example.com"

# -----------------------------------------------------------------------------
# Private CA — PEM file path (cannot inline multiline in .env)
# -----------------------------------------------------------------------------
PRIVATE_CA_PEM_FILE="./private-ca.pem"

# -----------------------------------------------------------------------------
# Control Plane Pool
# -----------------------------------------------------------------------------
CP_COUNT=3
CP_CPU="4"
CP_MEM="16"
CP_DISK=80

# -----------------------------------------------------------------------------
# General Worker Pool
# -----------------------------------------------------------------------------
GEN_CPU="4"
GEN_MEM="16"
GEN_DISK=60
GEN_MIN=4
GEN_MAX=10

# -----------------------------------------------------------------------------
# Compute Worker Pool
# -----------------------------------------------------------------------------
COMP_CPU="16"
COMP_MEM="32"
COMP_DISK=80
COMP_MIN=1
COMP_MAX=10

# -----------------------------------------------------------------------------
# Database Worker Pool
# -----------------------------------------------------------------------------
DB_CPU="4"
DB_MEM="24"
DB_DISK=80
DB_MIN=4
DB_MAX=10

# -----------------------------------------------------------------------------
# Docker Hub Auth (optional — avoids rate limits until Harbor mirrors are up)
# -----------------------------------------------------------------------------
# DOCKERHUB_USERNAME="your-dockerhub-user"
# DOCKERHUB_TOKEN="dckr_pat_xxxxx"

# -----------------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------------
SSH_USER="rocky"
SSH_KEY="ssh-ed25519 AAAA... user@host"

# -----------------------------------------------------------------------------
# Kubeconfig File Paths
# -----------------------------------------------------------------------------
CLOUD_PROVIDER_KUBECONFIG_FILE="./harvester-cloud-provider-kubeconfig"
CLOUD_CRED_KUBECONFIG_FILE="./kubeconfig-harvester-cloud-cred.yaml"
